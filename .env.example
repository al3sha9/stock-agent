# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Database Configuration (Supavisor)
# You can provide standard postgres:// or postgresql://; the app will auto-prefix with postgresql+asyncpg://
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# API Configuration
PROJECT_NAME="Stock Monitoring Agent"
API_V1_STR="/api/v1"

# AI Agent Configuration
GOOGLE_API_KEY=your-google-api-key-here
FMP_API_KEY=your-fmp-api-key-here
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
# Optional: Cloudflare reverse proxy for Telegram API (leave empty to use default)
# Example: https://telegram-proxy.your-worker.workers.dev/bot
TELEGRAM_BASE_URL=
